ISO-10303-21;
HEADER;
FILE_DESCRIPTION(('Box Room 5m x 4m x 3m'),'2;1');
FILE_NAME('box_room.step','2025-01-01',('EchoMap'),('EchoMap'),'','EchoMap','');
FILE_SCHEMA(('AUTOMOTIVE_DESIGN'));
ENDSEC;
DATA;
/* Cartesian points - 8 corners of the box */
#10=CARTESIAN_POINT('',(0.,0.,0.));
#11=CARTESIAN_POINT('',(5.,0.,0.));
#12=CARTESIAN_POINT('',(5.,4.,0.));
#13=CARTESIAN_POINT('',(0.,4.,0.));
#14=CARTESIAN_POINT('',(0.,0.,3.));
#15=CARTESIAN_POINT('',(5.,0.,3.));
#16=CARTESIAN_POINT('',(5.,4.,3.));
#17=CARTESIAN_POINT('',(0.,4.,3.));
/* Vertex points */
#20=VERTEX_POINT('',#10);
#21=VERTEX_POINT('',#11);
#22=VERTEX_POINT('',#12);
#23=VERTEX_POINT('',#13);
#24=VERTEX_POINT('',#14);
#25=VERTEX_POINT('',#15);
#26=VERTEX_POINT('',#16);
#27=VERTEX_POINT('',#17);
/* Directions */
#30=DIRECTION('',(0.,0.,1.));
#31=DIRECTION('',(1.,0.,0.));
#32=DIRECTION('',(0.,1.,0.));
#33=DIRECTION('',(0.,0.,-1.));
#34=DIRECTION('',(-1.,0.,0.));
#35=DIRECTION('',(0.,-1.,0.));
/* Edge curves - 12 edges of the box */
/* Bottom face edges */
#40=EDGE_CURVE('',#20,#21,$,.T.);
#41=EDGE_CURVE('',#21,#22,$,.T.);
#42=EDGE_CURVE('',#22,#23,$,.T.);
#43=EDGE_CURVE('',#23,#20,$,.T.);
/* Top face edges */
#44=EDGE_CURVE('',#24,#25,$,.T.);
#45=EDGE_CURVE('',#25,#26,$,.T.);
#46=EDGE_CURVE('',#26,#27,$,.T.);
#47=EDGE_CURVE('',#27,#24,$,.T.);
/* Vertical edges */
#48=EDGE_CURVE('',#20,#24,$,.T.);
#49=EDGE_CURVE('',#21,#25,$,.T.);
#50=EDGE_CURVE('',#22,#26,$,.T.);
#51=EDGE_CURVE('',#23,#27,$,.T.);
/* Oriented edges for each face */
/* Floor (z=0): #20-#21-#22-#23 */
#60=ORIENTED_EDGE('',*,*,#40,.T.);
#61=ORIENTED_EDGE('',*,*,#41,.T.);
#62=ORIENTED_EDGE('',*,*,#42,.T.);
#63=ORIENTED_EDGE('',*,*,#43,.T.);
/* Ceiling (z=3): #24-#27-#26-#25 */
#64=ORIENTED_EDGE('',*,*,#47,.F.);
#65=ORIENTED_EDGE('',*,*,#46,.F.);
#66=ORIENTED_EDGE('',*,*,#45,.F.);
#67=ORIENTED_EDGE('',*,*,#44,.F.);
/* Front wall (y=0): #20-#24-#25-#21 */
#68=ORIENTED_EDGE('',*,*,#48,.T.);
#69=ORIENTED_EDGE('',*,*,#44,.T.);
#70=ORIENTED_EDGE('',*,*,#49,.F.);
#71=ORIENTED_EDGE('',*,*,#40,.F.);
/* Back wall (y=4): #22-#26-#27-#23 */
#72=ORIENTED_EDGE('',*,*,#50,.T.);
#73=ORIENTED_EDGE('',*,*,#46,.T.);
#74=ORIENTED_EDGE('',*,*,#51,.F.);
#75=ORIENTED_EDGE('',*,*,#42,.F.);
/* Left wall (x=0): #23-#27-#24-#20 */
#76=ORIENTED_EDGE('',*,*,#51,.T.);
#77=ORIENTED_EDGE('',*,*,#47,.T.);
#78=ORIENTED_EDGE('',*,*,#48,.F.);
#79=ORIENTED_EDGE('',*,*,#43,.F.);
/* Right wall (x=5): #21-#25-#26-#22 */
#80=ORIENTED_EDGE('',*,*,#49,.T.);
#81=ORIENTED_EDGE('',*,*,#45,.T.);
#82=ORIENTED_EDGE('',*,*,#50,.F.);
#83=ORIENTED_EDGE('',*,*,#41,.F.);
/* Edge loops */
#90=EDGE_LOOP('',(#60,#61,#62,#63));
#91=EDGE_LOOP('',(#64,#65,#66,#67));
#92=EDGE_LOOP('',(#68,#69,#70,#71));
#93=EDGE_LOOP('',(#72,#73,#74,#75));
#94=EDGE_LOOP('',(#76,#77,#78,#79));
#95=EDGE_LOOP('',(#80,#81,#82,#83));
/* Face bounds */
#100=FACE_OUTER_BOUND('',#90,.T.);
#101=FACE_OUTER_BOUND('',#91,.T.);
#102=FACE_OUTER_BOUND('',#92,.T.);
#103=FACE_OUTER_BOUND('',#93,.T.);
#104=FACE_OUTER_BOUND('',#94,.T.);
#105=FACE_OUTER_BOUND('',#95,.T.);
/* Axis placements for planes */
#110=AXIS2_PLACEMENT_3D('',#10,#30,#31);
#111=AXIS2_PLACEMENT_3D('',#14,#33,#31);
#112=AXIS2_PLACEMENT_3D('',#10,#35,#31);
#113=AXIS2_PLACEMENT_3D('',#12,#32,#31);
#114=AXIS2_PLACEMENT_3D('',#13,#34,#32);
#115=AXIS2_PLACEMENT_3D('',#11,#31,#32);
/* Planes */
#120=PLANE('',#110);
#121=PLANE('',#111);
#122=PLANE('',#112);
#123=PLANE('',#113);
#124=PLANE('',#114);
#125=PLANE('',#115);
/* Advanced faces */
#130=ADVANCED_FACE('Floor',(#100),#120,.T.);
#131=ADVANCED_FACE('Ceiling',(#101),#121,.T.);
#132=ADVANCED_FACE('Front Wall',(#102),#122,.T.);
#133=ADVANCED_FACE('Back Wall',(#103),#123,.T.);
#134=ADVANCED_FACE('Left Wall',(#104),#124,.T.);
#135=ADVANCED_FACE('Right Wall',(#105),#125,.T.);
/* Shell and solid */
#140=CLOSED_SHELL('',(#130,#131,#132,#133,#134,#135));
#150=MANIFOLD_SOLID_BREP('Box Room',#140);
ENDSEC;
END-ISO-10303-21;
